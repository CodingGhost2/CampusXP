# Copy to `.env` for local development (never commit `.env`).
# Expo inlines `EXPO_PUBLIC_*` at bundle time — safe for Supabase anon key only.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
EXPO_PUBLIC_SUPABASE_STORAGE_BUCKET=task-proofs

# Optional: full POST endpoint for AI task generation.
# Expected contract:
#   request body: { "goal": "string" }
#   response body: { "tasks": [{ "title": "string", "xp_value": 20 }] }
EXPO_PUBLIC_AI_GATEWAY_URL=
